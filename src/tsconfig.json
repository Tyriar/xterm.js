{
  "extends": "./tsconfig-base",
  "compilerOptions": {
    "module": "commonjs",
    "lib": [
      "dom",
      "scripthost",
      "es6"
    ],
    "rootDir": ".",
    "outDir": "../out",
    "baseUrl": ".",
    "paths": {
      "common/*": [ "./common/*" ],
      "browser/*": [ "./browser/*" ]
    },

    "noUnusedLocals": true,
    "noImplicitAny": true
  },
  "include": [
    "./**/*",
    "../typings/xterm.d.ts"
  ],
  "exclude": [
    "./addons/**/*"
  ],
  "references": [
    { "path": "./common" },
    { "path": "./browser" }
  ]
}
